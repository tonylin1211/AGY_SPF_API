# 永豐期貨 Shioaji API 設定範本
# 請將此檔案複製為 .env 並填入實際的 API 金鑰資訊

# API 金鑰與密鑰 (若未填寫或登入失敗，程式會自動進入 Mock Fallback 模擬演示模式)
SHIOAJI_API_KEY=your_api_key_here
SHIOAJI_SECRET_KEY=your_secret_key_here

# 是否為模擬環境 (True / False)
SHIOAJI_SIMULATION=True

# 交易安全憑證設定 (執行真實委託下單/模擬下單與生成測試報告時必須配置)
# 憑證路徑，副檔名通常為 .pfx
SHIOAJI_CA_PATH=/Users/your_username/SinoPac.pfx
# 憑證密碼
SHIOAJI_CA_PASSWORD=your_ca_password_here
# 身分證字號 / 統一編號 (非必填，程式會嘗試從登入帳號中自動讀取)
SHIOAJI_PERSON_ID=your_id_number_here

